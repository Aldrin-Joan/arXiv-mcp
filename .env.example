# arxiv-mcp Environment Configuration
# Copy this file to .env and adjust as needed

# Directory where downloaded PDFs are cached
ARXIV_DOWNLOAD_DIR=./downloads

# Default number of search results
ARXIV_MAX_RESULTS=10

# Token chunking configuration
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=100

# Rate limiting: seconds between arXiv API calls (min 3s per arXiv ToS)
ARXIV_RATE_LIMIT_DELAY=3.0

# HTTP configuration
HTTP_TIMEOUT=60
MAX_RETRIES=3

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
